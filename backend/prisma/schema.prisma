generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ChatLog {
  id             Int       @id @default(autoincrement())
  runId          String
  conversationId String?
  startedAt      DateTime
  endedAt        DateTime?
  durationMs     Int?
  totals         String?
  apiCalls       String?
  messages       String
  createdAt      DateTime  @default(now())

  @@map("chat_logs")
}

model Spec {
  id        Int      @id @default(autoincrement())
  testname  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("specs")
}

model Environment {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  comment   String?
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("environments")
}

model Group {
  id        String   @id
  name      String
  testsJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("groups")
}

model TestAlias {
  testkey String @id
  alias   String

  @@map("test_aliases")
}

model RunHistory {
  filename      String @id
  durationsJson String

  @@map("run_history")
}

model Session {
  id         Int      @id @default(autoincrement())
  allJson    String
  failedJson String
  updatedAt  DateTime @updatedAt

  @@map("sessions")
}

model TestAction {
  testname        String   @id
  file            String
  description     String
  actionsJson     String
  environmentId   Int?
  environmentName String?
  updatedAt       DateTime @updatedAt

  @@map("test_actions")
}

model TestPrompt {
  testname     String   @id
  messagesJson String
  updatedAt    DateTime @updatedAt

  @@map("test_prompts")
}

model SavedChat {
  id           Int      @id @default(autoincrement())
  filename     String   @unique
  messagesJson String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("saved_chats")
}

// One global queue for every AI call — conversation turns and correction
// turns alike — so only one is ever in flight at a time, matching the
// existing "one Playwright process at a time" constraint (RunTest is
// reachable from both). Rows persist across a restart: anything still
// "queued" resumes as-is, anything caught mid-"running" gets reset to
// "queued" (its in-flight Claude call is gone either way, so it just
// retries from the same message) — see aiQueue.js's startup recovery.
model AiQueueTask {
  id           Int       @id @default(autoincrement())
  kind         String // "conversation" | "correction"
  targetKey    String // sessionId (conversation) or test filename (correction)
  message      String
  imagesJson   String? // base64 images attached to the message, if any
  instructions String? // conversation-only: system-prompt add-on from the client
  environmentId Int? // conversation-only
  seedHistoryJson String? // conversation-only: client-seeded history for a resumed thread
  status       String    @default("queued") // "queued" | "running"
  runId        String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?

  @@map("ai_queue_tasks")
}
